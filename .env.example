# Elektron Net node running in your private network 192.168.1.0/24
ELEKTRON_RPC_URL=http://192.168.1.100

# Elektron Net node running undockered on the same PC
# needs to add rpcallowip=172.16.0.0/12 to your elektron.conf
#ELEKTRON_RPC_URL=http://host.docker.internal

ELEKTRON_RPC_USER=
ELEKTRON_RPC_PASSWORD=
ELEKTRON_RPC_PORT=8332
ELEKTRON_RPC_TIMEOUT=10000

# You can use this instead of ELEKTRON_RPC_USER and ELEKTRON_RPC_PASSWORD
ELEKTRON_RPC_COOKIEFILE=

# Enable in elektron.conf with
# zmqpubrawblock=tcp://*:3000
# ELEKTRON_ZMQ_HOST="tcp://192.168.1.100:3000"

API_PORT=3334
STRATUM_PORT=3333
STRATUM_MAX_CONNECTIONS_PER_LISTENER=10000

# Per-miner template push cadence. Lower values keep ntime advancing for
# high-end ASICs (Bitaxe Gamma, Antminer S21) that exhaust the
# (nonce, version) search space inside a single ntime window; raise it if your
# upstream node strains under getblocktemplate load. clearJobs is only set on
# height changes, so a faster cadence does not invalidate in-flight work.
# Min 1000 ms (hard floor), default 30000.
JOB_REFRESH_INTERVAL_MS=30000

# How often the per-session vardiff re-evaluates the share submission rate
# and adjusts the session difficulty. Min 5000 ms (hard floor), default 60000.
DIFFICULTY_CHECK_INTERVAL_MS=60000

#optional telegram bot
#TELEGRAM_BOT_TOKEN=

#optional discord bot
#DISCORD_BOT_CLIENTID=
#DISCORD_BOT_GUILD_ID=
#DISCORD_BOT_CHANNEL_ID=

#optional
DEV_FEE_ADDRESS=
# Elektron Net: mainnet | regtest
# Bitcoin compat (for upstream testing only): bitcoin-mainnet | bitcoin-testnet | bitcoin-regtest
NETWORK=mainnet

API_SECURE=false
# Default is "Public-Pool", you can change it to any string it will be removed if it will make the block or coinbase script too big
POOL_IDENTIFIER="Elektron-Pool"

# Hobby-miner compatibility: comma-separated userAgent substrings (case-insensitive).
# Matching miners get a low starting difficulty so a few-kH/s ESP32 device
# actually submits shares before the pool's dead-client timeout fires. The pool
# already runs header-only mining (EXTRANONCE2_SIZE_BYTES = 0), so no special
# wire format is needed; only the difficulty is tuned for these devices.
# Substring allow-list (case-insensitive) of userAgents that need the HOBBY
# compatibility mode: non-empty extranonce1 in the subscribe response (to avoid
# the firmware aborting on empty), and a low starting difficulty. Currently
# only the NerdMiner_v2 family ships with this non-spec firmware behaviour.
# Bitaxe (ESP-Miner) and modern ASICs (Antminer, Whatsminer) are
# Stratum-compliant and should stay in NORMAL mode where shares actually
# validate. Add a userAgent substring here only if the device disconnects on
# empty extranonce1.
HOBBY_MINER_USER_AGENTS=NerdMiner,NerdminerV2,nerdminer,NerdAxe,NerdQAxe
HOBBY_MINER_DIFFICULTY=0.001

# Per-share diagnostic logging. Comma-separated list of header-reconstruction
# hypotheses to test on every mining.submit, or "all" for every mode, or empty
# to disable. Each enabled mode appends one `mode=<diff>` field to the [diag]
# log line so you can compare the canonical (= submitted) share difficulty
# against alternate firmware behaviours. Use to narrow down what a hobby-miner
# firmware actually splices into the coinbase before computing the merkle root.
#
# Available modes:
#   canonical            no splice (= the value used for the share OK check)
#   suffix-en1           coinbase || extranonce1
#   suffix-en1-en2       coinbase || extranonce1 || extranonce2  (classic Stratum)
#   suffix-en1-default-en2  coinbase || extranonce1 || "00000001"   (NerdMiner v1.8.3 hardcoded fallback when extranonce2_size=0)
#   suffix-zero4         coinbase || 0x00000000                  (hardcoded extranonce)
#   suffix-zero8         coinbase || 0x0000000000000000
#   prefix-en1           extranonce1 || coinbase                 (splice at start)
#   suffix-en1-reversed  coinbase || byte-reversed extranonce1   (endianness bug)
#   scriptsig-en1        extranonce1 spliced inside vin[0].scriptSig (spec-compliant)
#
# Example: DIAGNOSTIC_SHARE_LOGGING_MODES=canonical,suffix-en1,scriptsig-en1
DIAGNOSTIC_SHARE_LOGGING_MODES=
